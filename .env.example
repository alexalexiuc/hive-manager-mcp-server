# Google Service Account JSON (full stringified JSON)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional: pre-known spreadsheet ID to skip setup lookup on every request
SPREADSHEET_ID=

# Optional: folder configuration for setup/e2e lookup
HIVES_FOLDER_NAME=Hives
HIVES_FOLDER_ID=
HIVES_E2E_FOLDER_NAME=e2e
E2E_SPREADSHEET_NAME=hive_manager

# Server
PORT=3000
