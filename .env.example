# Google Service Account JSON (full stringified JSON)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# OAuth credentials for MCP connector authentication
OAUTH_CLIENT_ID=replace-with-client-id
OAUTH_CLIENT_SECRET=replace-with-strong-random-secret

# Required for e2e tests
E2E_SPREADSHEET_ID=

# Server
PORT=3000
